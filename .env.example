# Basis-URL deiner Paperless-ngx-Instanz.
# http:// im LAN ist völlig in Ordnung und wird nicht umgeschrieben.
PAPERLESS_URL=http://paperless.local:8000

# Paperless: Einstellungen -> Benutzer -> API-Token
PAPERLESS_TOKEN=

# Query-Endpoint der zu synchronisierenden Notion-Datenbank.
# DATABASE_ID ist der Teil der Notion-URL vor dem "?v=".
NOTION_URL=https://api.notion.com/v1/databases/<DATABASE_ID>/query

# Notion: https://www.notion.so/my-integrations -> Internal Integration Secret.
# Die Integration muss über "Connections" Zugriff auf die Datenbank bekommen.
NOTION_TOKEN=

# Optional: Sekunden zwischen zwei Sync-Durchläufen (Standard: 300).
SYNC_INTERVAL_SECS=300
