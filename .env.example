# Base URL of your Paperless-ngx instance.
# http:// on a LAN is perfectly fine and is never rewritten.
PAPERLESS_URL=http://paperless.local:8000

# Paperless: Settings -> Users -> API token
PAPERLESS_TOKEN=

# Query endpoint of the Notion database to sync.
# DATABASE_ID is the part of the Notion URL before "?v=".
NOTION_URL=https://api.notion.com/v1/databases/<DATABASE_ID>/query

# Notion: https://www.notion.so/my-integrations -> Internal Integration Secret.
# The integration needs access to the database via "Connections".
NOTION_TOKEN=

# Optional: seconds between sync cycles (default: 300).
SYNC_INTERVAL_SECS=300
